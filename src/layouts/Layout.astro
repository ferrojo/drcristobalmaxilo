---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
}

const {
  title,
  description = "Especialistas en cirugía bucal y maxilofacial en Guadalajara. Implantes dentales, cirugía ortognática y más.",
  currentPage = "",
} = Astro.props;

const navLinks = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios" },
  { label: "Mi Trabajo", href: "/mitrabajo" },
  { label: "Sobre el Dr.", href: "/doctor" },
  { label: "Contacto", href: "/contacto" },
];
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Dr. Cristóbal Patiño</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Manrope:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- TopNavBar -->
    <nav
      id="nav-header"
      class="fixed top-0 w-full z-50 bg-navy backdrop-blur-md border-b border-teal/20 h-16 md:h-24 transition-all duration-300 ease-in-out shadow-sm"
    >
      <div
        class="max-w-container mx-auto px-6 h-full flex items-center justify-between"
      >
        <a href="/" class="flex items-center gap-2 md:gap-3 group">
          <img
            id="nav-logo"
            src="/maxilo-logo.jpg"
            alt="Dr. Cristóbal Patiño Rojo Logo"
            class="h-10 w-auto md:h-20 md:w-35 rounded-full object-cover ring-2 ring-teal/40 group-hover:ring-teal transition-all duration-300"
          />
          <span
            id="nav-title"
            class="text-sm md:text-lg font-bold tracking-tight text-white uppercase font-doctor antialiased leading-tight transition-all duration-300"
          >
            Dr. Cristóbal Patiño
          </span>
        </a>

        <!-- Desktop Nav -->
        <div class="hidden md:flex items-center space-x-8">
          {
            navLinks.map((link) => (
              <a
                href={link.href}
                class={`font-medium transition-colors text-lg ${
                  currentPage === link.href
                    ? "text-white border-b-2 border-white pb-0.5"
                    : "text-slate-200 hover:text-white"
                }`}
              >
                {link.label}
              </a>
            ))
          }
        </div>

        <!-- CTA Button (desktop only) -->
        <a
          href="/agendar"
          class="hidden md:inline-block bg-on-primary text-black px-6 py-3 rounded-xl font-normal text-cta hover:bg-primary hover:text-white transition-all duration-300 active:scale-95 border-2 border-primary"
        >
          Agendar Cita
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 text-slate-200 hover:text-white transition-colors"
          aria-label="Menú"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>

      <!-- Mobile Menu -->
      <div
        id="mobile-menu"
        class="hidden md:hidden bg-navy border-t border-teal/20 px-6 py-4 space-y-4"
      >
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="block text-slate-200 font-medium hover:text-white transition-colors"
            >
              {link.label}
            </a>
          ))
        }
        <a
          href="/agendar"
          class="block bg-primary text-white px-6 py-3 rounded-xl text-center font-cta text-sm"
        >
          Agendar Cita
        </a>
      </div>
    </nav>

    <!-- Page Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer
      class="w-full border-t border-slate-200 bg-slate-50 pt-12 pb-8 mt-20"
    >
      <div
        class="max-w-container mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-8"
      >
        <!-- Brand -->
        <div class="space-y-3">
          <div class="text-lg font-bold text-primary font-h1">MaxiloSalud</div>
          <p class="text-sm text-slate-500 leading-relaxed">
            Especialistas en Cirugía Bucal y Maxilofacial. Tecnología de
            vanguardia para tu bienestar.
          </p>
          <div class="flex items-center gap-3 text-sm text-slate-500">
            <span class="material-symbols-outlined text-base">schedule</span>
            Lun–Vie 9:00–20:00 | Sáb 9:00–14:00
          </div>
        </div>

        <!-- Quick links -->
        <div class="space-y-3">
          <p
            class="text-xs font-semibold text-slate-400 uppercase tracking-widest"
          >
            Sitio
          </p>
          <div class="space-y-2">
            {
              navLinks.map((link) => (
                <a
                  href={link.href}
                  class="block text-sm text-slate-500 hover:text-primary transition-colors"
                >
                  {link.label}
                </a>
              ))
            }
          </div>
        </div>

        <!-- Legal -->
        <div class="space-y-3">
          <p
            class="text-xs font-semibold text-slate-400 uppercase tracking-widest"
          >
            Legal
          </p>
          <div class="space-y-2">
            <a
              href="/privacidad"
              class="block text-sm text-slate-500 hover:text-primary transition-colors"
              >Aviso de Privacidad</a
            >
            <a
              href="/terminos"
              class="block text-sm text-slate-500 hover:text-primary transition-colors"
              >Términos de Servicio</a
            >
            <a
              href="/faq"
              class="block text-sm text-slate-500 hover:text-primary transition-colors"
              >Preguntas Frecuentes</a
            >
          </div>
        </div>
      </div>

      <div
        class="max-w-container mx-auto px-6 mt-10 pt-6 border-t border-slate-200 flex flex-col md:flex-row justify-between items-center gap-4"
      >
        <p class="text-xs text-slate-400">
          © 2026 Cirujano Maxilofacial | Cristóbal Patiño Rojo. Todos los
          derechos reservados.Sitio desarrollado por Fernando Patiño
        </p>
        <div class="flex items-center gap-4 text-slate-400">
          <a
            href="tel:+523312345678"
            class="hover:text-primary transition-colors"
          >
            <span class="material-symbols-outlined text-lg">phone</span>
          </a>
          <a
            href="mailto:contacto@maxilosalud.mx"
            class="hover:text-primary transition-colors"
          >
            <span class="material-symbols-outlined text-lg">mail</span>
          </a>
          <a
            href="https://maps.google.com"
            target="_blank"
            class="hover:text-primary transition-colors"
          >
            <span class="material-symbols-outlined text-lg">location_on</span>
          </a>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById("mobile-menu-btn");
      const menu = document.getElementById("mobile-menu");
      btn?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");
      });

      // ── Shrink nav on scroll ──────────────────────────────
      const nav = document.getElementById("nav-header");
      const logo = document.getElementById("nav-logo");
      const title = document.getElementById("nav-title");

      const SCROLL_THRESHOLD = 10;
      const isMobile = () => window.innerWidth < 768;

      function updateNav() {
        const scrolled = window.scrollY > SCROLL_THRESHOLD;
        const mobile = isMobile();

        if (nav) {
          // Mobile: 64px → 48px | Desktop: 96px → 64px
          nav.style.height = scrolled ? (mobile ? "48px" : "64px") : "";
          nav.classList.toggle("shadow-lg", scrolled);
          nav.classList.toggle("shadow-sm", !scrolled);
        }

        if (logo) {
          // Logo reducido al scrollear (mobile: oculta el cambio pues ya es pequeño)
          logo.style.height = scrolled && !mobile ? "44px" : "";
          logo.style.width = scrolled && !mobile ? "auto" : "";
        }

        if (title) {
          // Texto reducido al scrollear
          title.style.fontSize = scrolled ? (mobile ? "11px" : "16px") : "";
        }
      }

      window.addEventListener("scroll", updateNav, { passive: true });
      window.addEventListener("resize", updateNav, { passive: true });
      updateNav(); // estado inicial
    </script>
  </body>
</html>

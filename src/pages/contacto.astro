---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto" currentPage="/contacto">

  <section class="pt-40 pb-20 px-6">
    <div class="max-w-container mx-auto space-y-16">

      <!-- Header -->
      <div class="text-center space-y-4">
        <span class="font-label-caps text-label-caps text-secondary uppercase tracking-widest">Estamos aquí para ti</span>
        <h1 class="font-h1 text-h1 text-primary">Contáctanos</h1>
        <p class="font-body-lg text-body-lg text-on-surface-variant max-w-xl mx-auto">
          Resuelve tus dudas o agenda directamente. Nuestro equipo responde en menos de 24 horas.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

        <!-- Contact Info -->
        <div class="space-y-8">
          {[
            { icon: 'phone', label: 'Teléfono', value: '+52 (33) 1234-5678', href: 'tel:+523312345678' },
            { icon: 'mail', label: 'Correo', value: 'contacto@maxilosalud.mx', href: 'mailto:contacto@maxilosalud.mx' },
            { icon: 'location_on', label: 'Dirección', value: 'Av. López Mateos Sur 1234, Col. Chapalita, Guadalajara, Jalisco.', href: 'https://maps.google.com' },
            { icon: 'schedule', label: 'Horarios', value: 'Lun–Vie: 9:00–20:00 | Sáb: 9:00–14:00', href: null },
          ].map(item => (
            <div class="flex items-start gap-5">
              <div class="w-12 h-12 bg-secondary-container rounded-xl flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-secondary">{item.icon}</span>
              </div>
              <div>
                <p class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-widest mb-1">{item.label}</p>
                {item.href ? (
                  <a href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} class="text-primary font-medium hover:underline">
                    {item.value}
                  </a>
                ) : (
                  <p class="text-primary font-medium">{item.value}</p>
                )}
              </div>
            </div>
          ))}

          <!-- WhatsApp CTA -->
          <div class="pt-4">
            <a
              href="https://wa.me/521XXXXXXXXXX"
              target="_blank"
              class="whatsapp-green whatsapp-hover text-white px-8 py-4 rounded-xl font-cta text-cta flex items-center justify-center gap-3 transition-all active:scale-95 shadow-lg w-full sm:w-auto"
            >
              <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">chat</span>
              Escribir por WhatsApp
            </a>
          </div>
        </div>

        <!-- Map placeholder / CTA Card -->
        <div class="bg-surface-container-low rounded-2xl border border-outline-variant/30 overflow-hidden">
          <div class="h-56 bg-gradient-to-br from-secondary-container to-primary-fixed flex items-center justify-center">
            <div class="text-center space-y-2">
              <span class="material-symbols-outlined text-4xl text-primary" style="font-variation-settings: 'FILL' 1;">location_on</span>
              <p class="text-primary font-semibold">Ver en Google Maps</p>
            </div>
          </div>
          <div class="p-8 space-y-4">
            <h3 class="font-h3 text-h3 text-primary">Clínica MaxiloSalud</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed">
              Av. López Mateos Sur 1234<br/>Col. Chapalita, Guadalajara<br/>Jalisco, México CP 45040
            </p>
            <a
              href="https://maps.google.com"
              target="_blank"
              class="inline-flex items-center gap-2 text-primary font-semibold text-sm hover:underline"
            >
              <span class="material-symbols-outlined text-base">open_in_new</span>
              Abrir en Maps
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

---
import Layout from '../layouts/Layout.astro';

const valores = [
  {
    icon: 'balance',
    title: 'Ética',
    desc: 'Integridad absoluta en cada diagnóstico y tratamiento, priorizando siempre el bienestar y la transparencia con el paciente.',
  },
  {
    icon: 'biotech',
    title: 'Innovación',
    desc: 'Implementación de tecnología 3D y flujos digitales de última generación para lograr cirugías mínimamente invasivas.',
  },
  {
    icon: 'favorite',
    title: 'Calidad Humana',
    desc: 'Atención empática y personalizada que reconoce la individualidad de cada paciente en su proceso de recuperación.',
  },
];
---

<Layout title="Sobre el Dr." currentPage="/doctor">

  <!-- Doctor Profile Hero -->
  <section class="pt-32 pb-20 px-6 bg-white">
    <div class="max-w-container mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Photo -->
      <div class="relative">
        <div class="rounded-2xl overflow-hidden shadow-xl">
          <img
            src="/dr-cristobal patino-rojo-maxilo.jpg"
            alt="Dr. Cristóbal Patiño"
            class="w-full h-[600px] object-cover object-top"
          />
        </div>
        <div class="absolute bottom-6 left-6 right-6 bg-white/95 backdrop-blur rounded-xl px-6 py-4 shadow-lg">
          <p class="text-xs font-semibold text-secondary uppercase tracking-widest mb-1">Especialista Certificado</p>
          <p class="font-h3 text-h3 text-primary">Dr. Cristóbal Patiño</p>
        </div>
      </div>

      <!-- Info -->
      <div class="space-y-8 pt-6">
        <div class="space-y-4">
          <span class="font-label-caps text-label-caps text-secondary uppercase tracking-widest">Excelencia Clínica</span>
          <h1 class="font-h1 text-h1 text-primary">Excelencia en Cirugía Maxilofacial</h1>
          <p class="font-body-lg text-body-lg text-on-surface-variant leading-relaxed">
            Con más de 15 años de experiencia, el Dr. Alejandro Vargas se ha consolidado como un referente en cirugía ortognática y reconstrucción facial. Su enfoque combina la precisión quirúrgica con una visión estética integral para devolver no solo la función, sino la confianza a sus pacientes.
          </p>
        </div>

        <!-- Credentials -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="p-5 bg-surface-container-low rounded-xl border border-outline-variant/30">
            <p class="font-label-caps text-label-caps text-secondary uppercase tracking-widest mb-2">Especialización</p>
            <p class="font-semibold text-primary">Cirugía Bucal y Maxilofacial</p>
            <p class="text-sm text-on-surface-variant">Centro Médico Nacional, UNAM.</p>
          </div>
          <div class="p-5 bg-surface-container-low rounded-xl border border-outline-variant/30">
            <p class="font-label-caps text-label-caps text-secondary uppercase tracking-widest mb-2">Certificaciones</p>
            <p class="font-semibold text-primary">Consejo Mexicano de Cirugía</p>
            <p class="text-sm text-on-surface-variant">Recertificación vigente 2024–2029.</p>
          </div>
        </div>

        <!-- Mission Quote -->
        <div class="space-y-3">
          <h2 class="font-h3 text-h3 text-primary">Nuestra Misión</h2>
          <blockquote class="border-l-4 border-primary-fixed-dim pl-5 italic text-on-surface-variant leading-relaxed">
            "Transformar vidas a través de procedimientos quirúrgicos de vanguardia, garantizando la seguridad del paciente y resultados funcionales excepcionales que superen los estándares internacionales de cuidado médico."
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- Valores -->
  <section class="py-24 px-6 bg-primary">
    <div class="max-w-container mx-auto space-y-16">
      <div class="text-center space-y-3">
        <span class="font-label-caps text-label-caps text-primary-fixed-dim uppercase tracking-widest">Fundamentos Clínicos</span>
        <h2 class="font-h2 text-h2 text-white">Nuestros Valores</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {valores.map(v => (
          <div class="text-center space-y-4">
            <div class="w-16 h-16 bg-primary-container rounded-2xl flex items-center justify-center mx-auto">
              <span class="material-symbols-outlined text-white text-2xl">{v.icon}</span>
            </div>
            <h3 class="font-h3 text-h3 text-white">{v.title}</h3>
            <p class="text-primary-fixed-dim text-sm leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Aseguradoras -->
  <section class="py-16 px-6 bg-surface-container-low border-b border-outline-variant/30">
    <div class="max-w-container mx-auto text-center space-y-8">
      <p class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-widest">
        Convenios con Aseguradoras
      </p>
      <div class="flex flex-wrap justify-center items-center gap-12 opacity-40">
        {['AXA', 'MetLife', 'GNP', 'MAPFRE'].map(name => (
          <span class="text-slate-600 font-bold text-xl tracking-wider hover:opacity-100 transition-opacity cursor-default">
            {name}
          </span>
        ))}
      </div>
    </div>
  </section>

</Layout>

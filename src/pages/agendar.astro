---
import Layout from "../layouts/Layout.astro";

const WHATSAPP_NUMBER = "521XXXXXXXXXX"; // Reemplazar con número real
---

<Layout title="Agendar Cita" currentPage="/agendar">
  <section class="pt-32 pb-20 px-6">
    <div
      class="max-w-container mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-start"
    >
      <!-- Information Side -->
      <div class="space-y-8">
        <div class="space-y-4">
          <span
            class="font-label-caps text-label-caps text-primary uppercase tracking-widest"
            >Reserva Especializada</span
          >
          <h1 class="font-h1 text-h1 text-primary">
            Agenda tu consulta hoy mismo
          </h1>
          <p class="font-body-lg text-body-lg text-on-surface-variant max-w-md">
            Inicia tu camino hacia una mejor salud bucal con expertos en cirugía
            maxilofacial. Proceso rápido, seguro y personalizado.
          </p>
        </div>

        <!-- Process Steps -->
        <div
          class="space-y-6 bg-surface-container-low p-8 rounded-xl border border-outline-variant/30"
        >
          <h3 class="font-h3 text-h3 text-primary">¿Cómo funciona?</h3>
          {
            [
              {
                n: 1,
                title: "Completa tus datos",
                desc: "Ingresa tu información básica en el formulario de la derecha.",
              },
              {
                n: 2,
                title: "Redirección Segura",
                desc: "Serás redirigido a nuestro chat oficial de WhatsApp automáticamente.",
              },
              {
                n: 3,
                title: "Confirmación Final",
                desc: "Coordinamos el horario exacto directamente contigo en el chat.",
              },
            ].map((step) => (
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary-fixed-dim flex items-center justify-center text-primary font-bold">
                  {step.n}
                </div>
                <div>
                  <p class="font-semibold text-primary">{step.title}</p>
                  <p class="text-sm text-on-surface-variant">{step.desc}</p>
                </div>
              </div>
            ))
          }
        </div>

        <!-- Doctor Badge -->
        <div class="flex items-center gap-4 p-4 rounded-xl">
          <div
            class="w-16 h-16 rounded-full overflow-hidden border-2 border-white shadow"
          >
            <img
              src="/dr.cristobal.patino-rojo-cirujano-maxilofacial.jpg"
              alt="Dr. Alejandro Vargas"
              class="w-full h-full object-cover object-top"
            />
          </div>
          <div>
            <p class="font-bold text-primary">Dr. Cristóbal Patiño</p>
            <p class="text-sm text-on-surface-variant italic">
              Cirujano Maxilofacial Certificado
            </p>
          </div>
        </div>
      </div>

      <!-- Booking Form Card -->
      <div
        class="bg-surface-container-lowest p-8 md:p-10 rounded-xl shadow-[0px_4px_20px_rgba(26,82,118,0.08)] border border-outline-variant/30"
      >
        <div class="space-y-6" id="booking-form">
          <!-- Nombre -->
          <div class="space-y-2">
            <label
              class="font-label-caps text-label-caps text-on-surface-variant uppercase"
              for="nombre"
            >
              Nombre Completo
            </label>
            <input
              id="nombre"
              type="text"
              placeholder="Ej. Juan Pérez"
              class="w-full border-0 border-b-2 border-outline-variant bg-transparent py-3 focus:border-primary focus:ring-0 transition-colors font-body-md outline-none"
            />
          </div>

          <!-- Teléfono -->
          <div class="space-y-2">
            <label
              class="font-label-caps text-label-caps text-on-surface-variant uppercase"
              for="telefono"
            >
              Teléfono de Contacto
            </label>
            <input
              id="telefono"
              type="tel"
              placeholder="+52 000 000 0000"
              class="w-full border-0 border-b-2 border-outline-variant bg-transparent py-3 focus:border-primary focus:ring-0 transition-colors font-body-md outline-none"
            />
          </div>

          <!-- Motivo -->
          <div class="space-y-4">
            <label
              class="font-label-caps text-label-caps text-on-surface-variant uppercase"
            >
              Motivo de Consulta
            </label>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {
                [
                  "Implantes",
                  "Cirugía de Mandíbula",
                  "Terceros Molares",
                  "Otro",
                ].map((reason) => (
                  <label class="flex items-center p-4 border border-outline-variant rounded-xl cursor-pointer hover:bg-surface-container transition-all group has-[:checked]:border-primary has-[:checked]:bg-primary-fixed/30">
                    <input
                      class="w-4 h-4 text-primary focus:ring-primary border-outline"
                      name="reason"
                      type="radio"
                      value={reason}
                    />
                    <span class="ml-3 font-body-md text-on-surface group-hover:text-primary transition-colors">
                      {reason}
                    </span>
                  </label>
                ))
              }
            </div>
          </div>

          <!-- CTA -->
          <div class="pt-4 space-y-4">
            <button
              id="whatsapp-btn"
              type="button"
              class="w-full whatsapp-green whatsapp-hover text-white py-5 rounded-xl font-cta text-cta flex items-center justify-center gap-3 active:scale-95 transition-all shadow-lg"
            >
              <span
                class="material-symbols-outlined"
                style="font-variation-settings: 'FILL' 1;">chat</span
              >
              Confirmar Cita por WhatsApp
            </button>
            <p
              class="text-center text-xs text-on-surface-variant italic leading-relaxed"
            >
              Completa tus datos y serás redirigido a nuestro chat oficial para
              confirmar horario.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ WHATSAPP_NUMBER }}>
  document.getElementById("whatsapp-btn")?.addEventListener("click", () => {
    const nombre = document.getElementById("nombre").value.trim();
    const telefono = document.getElementById("telefono").value.trim();
    const motivo =
      document.querySelector('input[name="reason"]:checked')?.value ||
      "No especificado";

    if (!nombre || !telefono) {
      alert("Por favor completa tu nombre y teléfono antes de continuar.");
      return;
    }

    const mensaje = `Hola! Me llamo *${nombre}*.\nMotivo de consulta: *${motivo}*.\nTel: ${telefono}\n\nMe gustaría agendar una cita.`;
    const url = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(mensaje)}`;
    window.open(url, "_blank");
  });
</script>

---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Inicio" currentPage="/">
  <!-- Hero Section -->
  <section
    class="pt-32 pb-20 px-6 bg-gradient-to-br from-surface to-surface-container-low overflow-hidden"
  >
    <div
      class="max-w-container mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center"
    >
      <!-- Text Side -->
      <div class="space-y-8">
        <div class="space-y-2">
          <span
            class="inline-block font-label-caps text-sm font-bold text-primary uppercase tracking-widest bg-primary-fixed px-0 py-5 rounded-full"
          >
            Líderes en Cirugía Maxilofacial
          </span>
        </div>
        <h1 class="font-h1 text-h1 text-primary leading-tight">
          Cirugía Maxilofacial de Excelencia: <span class="text-black"
            >Salud y Estética Funcional</span
          >
        </h1>
        <p class="font-body-lg text-lg md:text-lg text-on-surface-variant max-w-lg">
          Especialistas en implantes dentales, cirugía ortognática y patología
          bucal con tecnología de vanguardia para resultados precisos y
          duraderos.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/agendar"
            class="whatsapp-green whatsapp-hover text-black px-4 py-5 rounded-xl font-cta text-lg flex items-center justify-center gap-2 transition-all active:scale-95 shadow-lg font-bold hover:text-white"
          >
            <span
              class="material-symbols-outlined"
              style="font-variation-settings: 'FILL' 1;">chat</span
            >
            Agendar Cita por WhatsApp
          </a>
          <a
            href="/servicios"
            class="border-2 border-primary text-primary px-4 py-5 rounded-xl font-cta text-lg flex items-center justify-center gap-2 hover:bg-primary hover:text-white transition-all font-bold"
          >
            Nuestros Servicios
          </a>
        </div>
      </div>

      <!-- Image Side -->
      <div class="relative">
        <div class="rounded-2xl overflow-hidden shadow-2xl">
          <img
            src="/maxilofacial-cristobal-patino-rojo.jpg"
            alt="Dr. Cristóbal Patiño Rojo - Cirujano Maxilofacial"
            class="w-full h-[460px] object-cover object-top"
          />
        </div>
        <!-- Badge flotante -->
        <div
          class="absolute bottom-6 left-6 bg-white rounded-xl shadow-lg px-5 py-3 flex items-center gap-3"
        >
          <span class="material-symbols-outlined text-primary">verified</span>
          <div>
            <p class="text-xs font-semibold text-primary">
              Certificación Oficial
            </p>
            <p class="text-xs text-on-surface-variant">
              Consejo Mexicano de Cirugía
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Cards -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-container mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        [
          {
            icon: "biotech",
            title: "Tecnología de Vanguardia",
            desc: "Equipamiento quirúrgico de última generación para procedimientos mínimamente invasivos y recuperación acelerada.",
          },
          {
            icon: "person_heart",
            title: "Atención Personalizada",
            desc: "Diseñamos cada plan de tratamiento de forma única, priorizando el bienestar y los objetivos estéticos de cada paciente.",
          },
          {
            icon: "military_tech",
            title: "Experiencia Especializada",
            desc: "Años de trayectoria en cirugías complejas avalan nuestra precisión técnica y resultados clínicos excepcionales.",
          },
        ].map((card) => (
          <div class="p-8 bg-surface-container-low rounded-xl border border-outline-variant/30 hover:shadow-[0px_4px_20px_rgba(26,82,118,0.08)] transition-shadow group">
            <div class="w-12 h-12 bg-secondary-container rounded-lg flex items-center group-hover:border-2 border-primary justify-center mb-5 group-hover:bg-primary-fixed transition-colors">
              <span class="material-symbols-outlined text-white transition-colors">
                {card.icon}
              </span>
            </div>
            <h3 class="font-h3 text-h3 text-primary mb-3">{card.title}</h3>
            <p class=" text-on-surface-variant leading-relaxed">
              {card.desc}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-20 px-6 bg-surface-container-low">
    <div class="max-w-container mx-auto space-y-12">
      <div class="text-center space-y-3">
        <span
          class="font-label-caps text-label-caps text-secondary uppercase tracking-widest"
          >Servicios Especializados</span
        >
        <h2 class="font-h2 text-h2 text-primary">
          Tratamientos Quirúrgicos Avanzados
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Big card -->
        <div
          class="relative rounded-2xl overflow-hidden h-full group cursor-pointer"
        >
          <img
            src="https://images.unsplash.com/photo-1609840114035-3c981b782dfe?w=800&q=80"
            alt="Implantes Dentales"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
          <div
            class="absolute inset-0 bg-gradient-to-t from-slate-900/80 to-transparent"
          >
          </div>
          <div class="absolute bottom-6 left-6">
            <h3 class="text-white font-h3 text-h3 mb-1">Implantes Dentales</h3>
            <p class="text-slate-200 text-sm">
              Restauración funcional y estética con la mayor tasa de éxito.
            </p>
            <a
              href="/servicios#implantes"
              class="inline-block mt-3 text-primary-fixed-dim text-sm font-semibold hover:underline"
            >
              Saber más →
            </a>
          </div>
        </div>

        <!-- Two small cards -->
        <div class="grid grid-rows-2 gap-8">
          {
            [
              {
                img: "https://images.unsplash.com/photo-1579684385127-1ef15d508118?w=600&q=80",
                title: "Cirugía Ortognática",
                desc: "Corrección de irregularidades de la mandíbula y simetría facial.",
                href: "/servicios#ortognatica",
              },
              {
                img: "https://images.unsplash.com/photo-1598256989800-fe5f95da9787?w=600&q=80",
                title: "Patología Bucal",
                desc: "Diagnóstico y tratamiento de lesiones en cavidad oral y maxilares.",
                href: "/servicios#patologia",
              },
            ].map((card) => (
              <div class="relative rounded-2xl overflow-hidden h-48 group cursor-pointer">
                <img
                  src={card.img}
                  alt={card.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-slate-900/75 to-transparent" />
                <div class="absolute bottom-4 left-5">
                  <h3 class="text-white font-semibold text-lg">{card.title}</h3>
                  <p class="text-slate-300 text-xs mt-1">{card.desc}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Trust / Aseguradoras -->
  <section class="py-16 px-6 bg-white border-y border-outline-variant/30">
    <div class="max-w-container mx-auto text-center space-y-8">
      <p
        class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-widest"
      >
        Convenios con las Principales Aseguradoras
      </p>
      <div class="flex flex-wrap justify-center items-center gap-10 opacity-50">
        {
          ["AXA", "MetLife", "GNP", "MAPFRE"].map((name) => (
            <span class="text-slate-500 font-bold text-lg tracking-wider hover:opacity-100 transition-opacity cursor-default">
              {name}
            </span>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
